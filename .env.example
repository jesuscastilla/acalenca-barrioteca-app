# Configuración de la PWA Barrioteca Acalencá
# Copia este archivo como .env y ajusta los valores

# URL base de la API de SLiMS en el NAS Synology
# NOTA: Ajusta esta ruta según la instalación real de SLiMS en tu NAS
SLIMS_API_BASE="https://pelotxo.synology.me/slims/api/v1"

# Puerto del servidor (por defecto 3000)
PORT=3000
