u# ─────────────────────────────────────────────────────
#  Barrioteca Acalencá — Variables de Entorno
#  Copia este archivo como .env y configura tus valores.
#  .env NO se sube al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────

# URL base de la API de SLiMS
# En desarrollo local:  http://localhost/slims/api/index.php
# En producción NAS:    https://TU-DOMINIO.synology.me/slims/api/index.php
SLIMS_API_BASE=http://localhost/slims/api/index.php

# Clave de API de Google Books (opcional, para obtener portadas y metadatos)
# Obtén una clave gratuita en: https://console.cloud.google.com/apis/credentials
GOOGLE_BOOKS_API_KEY=

# Puerto del servidor Node.js (por defecto 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# Endpoint de la API para el frontend (solo variables con prefijo VITE_ se exponen al cliente)
# En desarrollo con Node.js: /api
# En producción con NAS+Nginx: ./api-proxy.php (valor por defecto si no se define)
VITE_API_ENDPOINT=/api
